# =====================================================
# WA Blast Dashboard v2 — Environment Variables
# =====================================================
# Copy file ini jadi .env untuk lokal
# Di Railway: masukkan satu per satu di tab Variables
# =====================================================

# [WAJIB] Secret key untuk session login
# Generate sendiri: node -e "require('crypto').randomBytes(48).then??(v=>console.log(v.toString('hex')))"
# Contoh (JANGAN pakai yang ini di production!):
SESSION_SECRET=GANTI_DENGAN_KEY_ACAK_PANJANG

# [OTOMATIS] Port — Railway set otomatis, jangan diubah
# PORT=3000

# [OPTIONAL] NOKOS API integration (admin tab)
NOKOS_API_KEY=
NOKOS_API_BASE=https://api.nokos.co.id
NOKOS_TIMEOUT_MS=15000
NOKOS_APPLICATION_PATHS=/api/applications,/api/services,/v1/applications,/v1/services
NOKOS_RANGE_PATHS=/api/ranges,/api/top-ranges,/v1/ranges,/v1/top-ranges
